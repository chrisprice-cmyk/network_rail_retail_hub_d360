{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "yaml.schemas": {
    "https://qlabs-org.my.site.com/qverse/resource/1740162235000/cumulusci_jsonschema_json": "/*"
  },
  "[xml]": {
    "editor.defaultFormatter": "redhat.vscode-xml"
  },
  "editor.trimAutoWhitespace": true,
  "files.associations": {
    "*.resource": "robotframework",
    "*.robot": "robotframework"
  },
  "files.exclude": {
    "**/__pycache__": true,
    "**/._*": true,
    "**/.cci": true,
    "**/.devcontainer": true,
    "**/.eslintrc.json": true,
    "**/.forceignore": true,
    "**/.github": true,
    "**/.gitignore": true,
    "**/.prettierignore": true,
    "**/.prettierrc": true,
    "**/.qbrix": true,
    "**/.sf": true,
    "**/.sfdx": true,
    "**/.vscode": true,
    "**/*.pyc": true,
    "**/bower_components": true,
    "**/jest.config.js": true,
    "**/node_modules": true,
    "**/package.json": true,
    "**/playwright.config.ts": true
  },
  "git.branchProtection": [
    "main",
    "master"
  ],
  "python.terminal.activateEnvironment": true,
  "robot.pythonpath": [
    "${workspaceFolder}",
    "${workspaceFolder}/qbrix_local",
    "qx/qrobot/keywords"
  ],
  "robotcode.robot.pythonPath": [
    "${workspaceFolder}",
    "${workspaceFolder}/qbrix_local",
    "qx/qrobot/keywords"
  ],
  "salesforcedx-vscode-core.push-or-deploy-on-save.enabled": false,
  "search.exclude": {
    "**/.cci": true,
    "**/.devcontainer": true,
    "**/.github": true,
    "**/.sf": true,
    "**/.sfdx": true,
    "**/.vscode": true,
    "**/bower_components": true,
    "**/node_modules": true
  }
}