{
  "cSpell.words": ["cumulusci", "robotframework", "qbrix", "brix"],
  "robot.pythonpath": [
    "${workspaceFolder}",
    "${workspaceFolder}/qbrix_local",
    "qx/qrobot/keywords"
  ],
  "[python]": {
    "editor.defaultFormatter": "ms-python.black-formatter"
  },
  "python.defaultInterpreterPath": "~/.local/pipx/venvs/cumulusci/bin/python",
  "python.terminal.activateEnvironment": true,
  "secrets.enabledFolders": ["default", "qbrix_secrets"]
}
