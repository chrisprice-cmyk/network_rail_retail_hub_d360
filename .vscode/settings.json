{
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.detectIndentation": false,
  "editor.insertSpaces": true,
  "editor.tabSize": 4,
  "editor.trimAutoWhitespace": true,
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[robot]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 4
  },
  "[xml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "[yaml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
    "editor.insertSpaces": true,
    "editor.tabSize": 2
  },
  "eslint.validate": [
    "javascript",
    "javascriptreact"
  ],
  "files.associations": {
    "*.resource": "robotframework",
    "*.robot": "robotframework"
  },
  "files.exclude": {
    "**/__pycache__": false,
    "**/.mypy_cache": false,
    "**/.claude": false,
    "**/.gemini": false,
    "**/.cursor": false,
    "**/.extensions": false,
    "**/.plugins": false,
    "**/.pytest_cache": false,
    "**/._*": false,
    "**/.cci": false,
    "**/.zed": false,
    "**/.editorconfig": false,
    "**/.cursorrules": false,
    "**/.devcontainer": false,
    "**/.eslintrc.json": false,
    "**/.forceignore": false,
    "**/.gitattributes": false,
    "**/.github": false,
    "**/.gitignore": false,
    "**/.prettierignore": false,
    "**/.prettierrc": false,
    "**/.qbrix": false,
    "**/.sf": false,
    "**/.sfdx": false,
    "**/.vscode": false,
    "**/.windsurf": false,
    "**/*.pyc": false,
    "**/bower_components": false,
    "**/jest.config.js": false,
    "**/node_modules": false,
    "**/package.json": false,
    "**/playwright.config.ts": false,
    "**/tsconfig.json": false,
    "**/eslint.config.js": false,
    "Makefile": false,
    "package-lock.json": false,
    ".mcp.json": false,
    "SUPPORT.md": false,
    "CODE_OF_CONDUCT.md": false,
    "SECURITY.md": false,
    "LICENSE.md": false,
    "CLAUDE.md": false
  },
  "search.exclude": {
    "**/.cci": true,
    "**/.claude": false,
    "**/.cursorrules": false,
    "**/.devcontainer": true,
    "**/.github": true,
    "**/.sf": true,
    "**/.sfdx": true,
    "**/.vscode": true,
    "**/.windsurf": false,
    "**/.zed": true,
    "**/bower_components": true,
    "**/node_modules": true
  },
  "git.branchProtection": [
    "main",
    "master"
  ],
  "python.terminal.activateEnvironment": true,
  "robot.pythonpath": [
    "${workspaceFolder}",
    "${workspaceFolder}/qbrix_local",
    "qx/qrobot/keywords"
  ],
  "robotcode.robot.pythonPath": [
    "${workspaceFolder}",
    "${workspaceFolder}/qbrix_local",
    "qx/qrobot/keywords"
  ],
  "salesforce.einsteinForDevelopers.enable": false,
  "salesforcedx-vscode-apex.languageServer.restartBehavior": "restart",
  "salesforcedx-vscode-core.experimental.enableSourceTrackingForDeployAndRetrieve": false,
  "salesforcedx-vscode-core.push-or-deploy-on-save.enabled": false,
  "salesforcedx-vscode-core.push-or-deploy-on-save.ignoreConflictsOnPush": true,
  "salesforcedx-vscode-core.retrieve-test-code-coverage": true,
  "analyticsdx-vscode-core.CLI.checkForPlugin": false,
  "yaml.schemas": {
    "https://qlabs-org.my.site.com/qverse/resource/1740162235000/cumulusci_jsonschema_json": "/*"
  },
  "xml.preferences.showSchemaDocumentationType": "none"
}