root = true
# Default coding style for all files
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

# Apex code
[*.cls]
indent_style = space
indent_size = 4

# Triggers
[*.trigger]
indent_style = space
indent_size = 4

# XML metadata
[*.xml]
indent_style = space
indent_size = 2

# JavaScript files
[*.js]
indent_style = space
indent_size = 2

# HTML files
[*.html]
indent_style = space
indent_size = 2

# JSON files
[*.json]
indent_style = space
indent_size = 2
