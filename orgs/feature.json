{
  "orgName": "xDO-Template - Feature Test Org",
  "edition": "enterprise",
  "features": [
    "PersonAccounts",
    "ServiceCloud",
    "SocialCustomerService",
    "EINSTEINANALYTICSPLUS",
    "LightningServiceConsole",
    "LightningSalesConsole",
    "LightningScheduler",
    "Chatbot",
    "LiveMessage",
    "LIVEAGENT",
    "Knowledge",
    "Communities",
    "Sites",
    "WavePlatform",
    "InsightsPlatform",
    "INSIGHTSSALESANALYTICS",
    "INSIGHTSSERVICEANALYTICS",
    "CASECLASSIFICATION",
    "CASEWRAPUP",
    "SALESCLOUDEINSTEIN",
    "SERVICEWORKFORCEMANAGEMENT",
    "FIELDSERVICE:1",
    "OrderManagement",
    "B2BCommerce",
    "CaseClassification",
    "CaseWrapUp",
    "CMSUnlimitedUse",
    "CPQ",
    "HighVelocitySales",
    "REMOTEVIDEOASSISTANCE",
    "VOICEENABLED",
    "ServiceUser",
    "SERVICECLOUDVOICEBYOA"
  ],
  "settings": {
      "botSettings": {
          "enableBots": true
      },
      "experienceBundleSettings": {
          "enableExperienceBundleMetadata": true
      },
      "liveMessageSettings": {
          "enableLiveMessage": true
      },
      "liveAgentSettings": {
          "enableLiveAgent": true
      },
      "knowledgeSettings": {
          "enableKnowledge": true,
          "enableLightningKnowledge": true
      },
      "omniChannelSettings": {
          "enableOmniChannel": true
      },
      "communitiesSettings": {
          "enableNetworksEnabled": true
      },
      "lightningExperienceSettings": {
          "enableS1DesktopEnabled": true
      },
      "pathAssistantSettings": {
          "pathAssistantEnabled": true
      },
      "mobileSettings": {
          "enableS1EncryptedStoragePref2": false
      },
      "securitySettings": {
        "enableAdminLoginAsAnyUser": true,
        "sessionSettings": {
          "forceRelogin": false
        }
      },
      "orderManagementSettings": {
        "enableOrderManagement": true
      },
      "orderSettings": {
        "enableOrders": true,
        "enableEnhancedCommerceOrders": true,
        "enableOptionalPricebook": true
      },
      "territory2Settings": {
        "enableTerritoryManagement2":true
      },
      "emailAdministrationSettings": {
        "enableEnhancedEmailEnabled": true
      },
      "serviceCloudVoiceSettings": {
        "enableServiceCloudVoice": true
      }
  }
}
