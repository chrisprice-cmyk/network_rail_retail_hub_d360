{
    "compilerOptions": {
        "target": "ES2020",
        "module": "CommonJS",
        "moduleResolution": "Node",
        "types": ["node", "@playwright/test"],
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": ["playwright.config.ts", "**/*.ts"],
    "exclude": [
        "node_modules",
        ".qbrix",
        "force-app",
        ".cci",
        ".sfdx",
        ".sf",
        ".windsurf",
        ".cursor",
        ".claude",
        ".gemini"
    ]
}
