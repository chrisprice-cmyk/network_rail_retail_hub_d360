{
  "mcpServers": {
    "Salesforce DX": {
      "command": "npx",
      "args": [
        "-y",
        "@salesforce/mcp",
        "--orgs",
        "DEFAULT_TARGET_ORG",
        "--toolsets",
        "orgs,metadata,data,users,testing,other,aura-experts,lwc-experts",
        "--allow-non-ga-tools"
      ]
    },
    "qx-mcp": {
      "type": "stdio",
      "command": "uvx",
      "args": ["--from", "git+https://github.com/sfdc-qbranch-emu/qx_mcp@main", "qx-mcp"]
    }
  }
}
