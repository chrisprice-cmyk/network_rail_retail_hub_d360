{
  "image": "ghcr.io/sfdc-qbranch/qbrix-base-container-quasar:latest",
  "forwardPorts": [7788, 1717, 6080],
  "portsAttributes": {
    "7788": {
      "label": "cci-auth-callback"
    },
    "1717": {
      "label": "sfdx-web-auth"
    },
    "6080": {
      "label": "qbrix robot vnc viewer"
    }
  },
  "remoteEnv": {
    // Use a GitHub Codespaces secret:
    "QSR_ENDPOINT": "${localEnv:QSR_ENDPOINT}",
    "QSR_JWT_SIGNING_SECRET": "${localEnv:QSR_JWT_SIGNING_SECRET}",
    "NEXTGEN_GATE_KEEPER_AUTH_URL": "${localEnv:NEXTGEN_GATE_KEEPER_AUTH_URL}",
    "NEXTGEN_GATE_KEEPER_CONSUMER_KEY": "${localEnv:NEXTGEN_GATE_KEEPER_CONSUMER_KEY}",
    "NEXTGEN_GATE_KEEPER_CONSUMER_SECRET": "${localEnv:NEXTGEN_GATE_KEEPER_CONSUMER_SECRET}"
  },
  "customizations": {
    // Configure properties specific to Codespaces.
    "codespaces": {
      //give read access to qbrix that might be dynamically loaded and need out of band access
      "repositories": {
        "sfdc-qbranch/qbrix_cli": {
          "permissions": "read-all"
        },
        "sfdc-qbranch/QBrix-0-xDO-BaseConfig": {
          "permissions": "read-all"
        },
        "sfdc-qbranch/QBrix-1-xDO-Tool-QBrixRegister": {
          "permissions": "read-all"
        },
        "sfdc-qbranch/QBrix-2-xDO-Tool-OrgIdentifier": {
          "permissions": "read-all"
        },
        "sfdc-qbranch/QBrix-2-xDO-Tool-demoappTrack": {
          "permissions": "read-all"
        },
        "sfdc-qbranch/QBrix-2-xDO-Tool-UtilityLookup": {
          "permissions": "read-all"
        },
        "sfdc-qbranch/QBrix-2-xDO-Tool-Spotter": {
          "permissions": "read-all"
        },
        "sfdc-qbranch/QBrix-3-SDO-Platform-Components": {
          "permissions": "read-all"
        },
        "sfdc-qbranch/QBrix-2-xDO-Tool-Mixpanel": {
          "permissions": "read-all"
        }
      }
    },
    // Configure properties specific to VS Code.
    "vscode": {
      // Set *default* container specific settings.json values on container create.
      "settings": {
        "salesforcedx-vscode-apex.java.home": "/usr/lib/jvm/java-11-openjdk-amd64"
      },

      // Add the IDs of extensions you want installed when the container is created.
      "extensions": [
        "salesforce.salesforcedx-vscode",
        "redhat.vscode-xml",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode",
        "king2021.vnc-extension",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-slideshow",
        "Postman.postman-for-vscode",
        "pomdtr.secrets"
      ]
    }
  },
  "features": {
    "desktop-lite": {
      "password": "vscode",
      "webPort": "6080",
      "vncPort": "5901"
    }
  },
  "postStartCommand": "qx setup init-codespace"
}
