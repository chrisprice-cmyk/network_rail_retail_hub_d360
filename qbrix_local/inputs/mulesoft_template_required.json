{
  "parameters": [
    {
      "friendly_name": "Mulesoft Username",
      "name": "mulesoft_username",                                                                                                                                                             
      "regex": "^[a-zA-Z0-9._%+-]+@salesforce\\.com$", 
      "default": "",
      "automated_test_value": "test@salesforce.com",
      "description": "The Mulesoft username that will be used for the deployment"
    },
    {
      "friendly_name": "Mulesoft Org ID",
      "name": "mulesoft_org_id",
      "regex": "^[a-zA-Z0-9-]+_[0-9]+$",
      "default": "",
      "automated_test_value": "GHAction_0",
      "description": "The Mulesoft Org ID where the assets will be deployed"
    },
    {
      "friendly_name": "Assets expiration date",
      "name": "mulesoft_expiration_date",
      "default": "None",
      "description": "Default expiration date is 180 days"
    },
    {
      "friendly_name": "Demo Title",
      "name": "mulesoft_demo_title",
      "default": "",
      "automated_test_value": "Github Test",
      "description": "Title to identify the deployment"
    },
    {
      "friendly_name": "Environment Type",
      "name": "mulesoft_env_type",
      "default": "None",
      "description": "Environment Type for the deployment"
    },
    {
      "friendly_name": "Environment Id",
      "name": "mulesoft_env_id",
      "default": "None",
      "description": "Environment ID for the deployment"
    },
    {
      "friendly_name": "Business Group Id",
      "name": "mulesoft_group_id",
      "default": "None",
      "description": "Business Group for the deployment"
    },
    {
      "friendly_name": "Opportunity ID",
      "name": "salesforce_opportunity_id",
      "default": "None",
      "description": "Org62 Opportunity ID that this deployment is linked to"
    }
  ]
}