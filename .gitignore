# =============================================================================
# CURSOR (AI code editor)
# .cursorignore and .cursorindexingignore control what Cursor indexes — these
# are personal preferences and should NOT be committed.
# Ref: https://docs.cursor.com/context/ignore-files
# =============================================================================
.cursorignore
.cursorindexingignore
.cursor/mcp.json

# =============================================================================
# CLAUDE (Anthropic Claude Code)
# .claude/settings.json  → COMMIT  (shared team config, MCP servers, permissions)
# .claude/settings.local.json → IGNORE (personal allow/deny overrides)
# CLAUDE.md              → COMMIT  (shared project instructions)
# =============================================================================
.claude/settings.local.json
.claude/todos/

# =============================================================================
# CODEX (OpenAI Codex CLI)
# .codex/config.toml     → COMMIT  (shared project config)
# .codex/config.local.toml → IGNORE (personal overrides)
# AGENTS.md              → COMMIT  (shared agent instructions)
# AGENTS.override.md     → IGNORE  (personal instruction overrides)
# Ref: https://developers.openai.com/codex/config-advanced
# =============================================================================
.codex/config.local.toml
AGENTS.override.md
.codex/history/
.codex/logs/

# =============================================================================
# MISC TOOL FILES
# =============================================================================
bin/dataloader/dataloader.jar
testim-headless.zip
dataloader-encrypted-password.txt
.cache/
hardis-report/
.sfdx-hardis.yml

# =============================================================================
# COMPILED / GENERATED OUTPUT
# =============================================================================
out/
