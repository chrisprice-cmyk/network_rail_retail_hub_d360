# This file is used for Git repositories to specify intentionally untracked files that Git should ignore.
# If you are not using git, you can delete this file. For more information see: https://git-scm.com/docs/gitignore
# For useful gitignore templates see: https://github.com/github/gitignore

# =============================================================================
# DEMO BRIX / Q-BRIX
# =============================================================================
.qbrix/
.backup/

# =============================================================================
# EXTENSIONS
# =============================================================================
.extensions/

# =============================================================================
# VSCODE
# Allow shared tasks, settings, snippets and MCP config; ignore personal/local.
# =============================================================================
.vscode/*
!.vscode/tasks.json
!.vscode/settings.json
!.vscode/brix.code-snippets
!.vscode/mcp.json
# [ADDED] Per-user local setting overrides should never be committed.
.vscode/settings.local.json
.vscode-test
*.code-workspace

# =============================================================================
# JETBRAINS (IntelliJ, IDEA, Illuminated Cloud, etc.)
# =============================================================================
.idea/
# [ADDED] Illuminated Cloud 2 generates a separate directory too
.illuminatedCloud2/
.illuminatedCloud/
IlluminatedCloud
cmake-build-*/
*.iws
out/
.idea_modules/
com_crashlytics_export_strings.xml
crashlytics.properties
crashlytics-build.properties
fabric.properties
qbrix/.idea/workspace.xml
target/
**/tsconfig*.json
!tsconfig.json
**/graphql.config.yml
# [ADDED] JetBrains shelf (local stash), shelf/, and workspace.xml are user-local
.idea/workspace.xml
.idea/shelf/
# [ADDED] JetBrains httpClient environment with secrets
.idea/httpRequests/http-client.private.env.json

# =============================================================================
# JUPYTER NOTEBOOKS
# =============================================================================
.ipynb_checkpoints
*/.ipynb_checkpoints/*
profile_default/
ipython_config.py

# =============================================================================
# MARIMO (reactive Python notebooks)
# =============================================================================
marimo/_static/
marimo/_lsp/
__marimo__/

# =============================================================================
# CUMULUSCI
# .cci/ holds local project state (scratch org aliases, source tracking, etc.)
# ~/.cumulusci/ holds global AES-encrypted keychains — already outside repo.
# src/ is the legacy mdapi source directory used by some CCI project templates.
# =============================================================================
.cci/
src/
# [ADDED] CumulusCI robot/test result artefacts
robot_results/
# [ADDED] CumulusCI local dataset snapshots (generated, not source)
datasets/generated/

# =============================================================================
# SALESFORCE DX  (sf CLI / sfdx)
# =============================================================================
.sfdx/
.sf/
.project
.settings/
.metadata
build.properties
**/lwc/jsconfig.json
config/user/*
generatedDelta/*
destructiveChanges/*
package/*
**/__tests__/**
coverage/
.localdevserver/
.localdev
deploy-options.json
apex-scripts/log
force-app/main/default/profiles/
force-app/main/default/appMenus/AppSwitcher.appMenu-meta.xml
force-app/main/default/flexipages/LightningService_UtilityBar.flexipage-meta.xml
# [ADDED] Salesforce Code Analyzer / Scanner results (generated output)
sca-results.csv
sfca_results.json
# [ADDED] JWT / certificate private keys used for CI auth (NEVER commit)
server.key
*.key
certs/
# [ADDED] B2C Commerce / Commerce Cloud credentials file
dw.json
# [ADDED] sf CLI temp files
.sf/tmp/
# [ADDED] Manifest folder generated during retrieve/deploy workflows
manifest/

